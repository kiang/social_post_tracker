{
  "manifest_version": 3,
  "name": "Threads Issue Reporter",
  "version": "1.1",
  "description": "Add a report button to Threads and Facebook posts to submit location-based reports to Google Forms",
  "permissions": ["storage"],
  "host_permissions": ["https://www.threads.net/*", "https://www.threads.com/*", "https://www.facebook.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.threads.net/*", "https://www.threads.com/*"],
      "js": ["leaflet.js", "content.js"],
      "css": ["leaflet.css", "content.css"]
    },
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["leaflet.js", "facebook.js"],
      "css": ["leaflet.css", "content.css"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["https://www.threads.net/*", "https://www.threads.com/*", "https://www.facebook.com/*"]
    }
  ]
}
